{
  "name": "daranger/php-starter",
  "description": "A modern PHP starter kit with MVC.",
  "type": "project",
  "keywords": ["php", "mvc", "starter-kit", "boilerplate", "framework", "admin-panel", "2fa"],
  "homepage": "https://github.com/daranger/php-starter",
  "license": "MIT",
  "support": {
    "issues": "https://github.com/daranger/php-starter/issues",
    "source": "https://github.com/daranger/php-starter"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    },
    "files": [
      "app/Helpers/helpers.php"
    ]
  },
  "require": {
    "php": ">=8.1",
    "predis/predis": "^3.5",
    "robthree/twofactorauth": "^3.0",
    "chillerlan/php-qrcode": "^6.0",
    "phpmailer/phpmailer": "^7.1"
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.5"
  }
}